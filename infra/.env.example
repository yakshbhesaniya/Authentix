# ─── Database ──────────────────────────────────────────────────────
POSTGRES_USER=authentix
POSTGRES_PASSWORD=authentix_secret
POSTGRES_DB=authentix
DATABASE_URL=postgresql://authentix:authentix_secret@localhost:5432/authentix

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO / S3 ────────────────────────────────────────────────────
MINIO_ROOT_USER=authentix
MINIO_ROOT_PASSWORD=authentix_secret
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=authentix
MINIO_SECRET_KEY=authentix_secret
MINIO_BUCKET=authentix-documents

# ─── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_256_BIT_RANDOM_KEY
JWT_EXPIRY=7d

# ─── Service URLs (local dev) ──────────────────────────────────────
INGESTION_URL=http://localhost:8001
PLAGIARISM_URL=http://localhost:8002
AI_DETECTION_URL=http://localhost:8003
HUMANIZER_URL=http://localhost:8004
EVALUATION_URL=http://localhost:8005

# ─── Qdrant ────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Gateway ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
MAX_FILE_SIZE_MB=50

# ─── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
